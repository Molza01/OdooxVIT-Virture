generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DIRECTOR
  FINANCE
  MANAGER
  EMPLOYEE
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalAction {
  APPROVED
  REJECTED
  PENDING
}

enum PaidBy {
  PERSONAL
  COMPANY
}

enum RuleType {
  PERCENTAGE
  SPECIFIC_APPROVER
  HYBRID
}

model Company {
  id        String   @id @default(uuid())
  name      String
  country   String   @default("United States")
  currency  String   @default("USD") @db.VarChar(3)
  domain    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  workflows ApprovalWorkflow[]
  rules     ApprovalRule[]

  @@map("companies")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  role            Role     @default(EMPLOYEE)
  companyId       String   @map("company_id")
  managerId       String?  @map("manager_id")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager         User?    @relation("ManagerSubordinates", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates    User[]   @relation("ManagerSubordinates")

  expenses        Expense[]
  approvalActions ExpenseApproval[] @relation("Approver")
  assignedSteps   ApprovalStep[]

  @@index([companyId])
  @@index([managerId])
  @@index([email])
  @@map("users")
}

model Expense {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  companyId   String        @map("company_id")
  title       String?
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD") @db.VarChar(3)
  convertedAmount Decimal?  @map("converted_amount") @db.Decimal(12, 2)
  companyCurrency String?   @map("company_currency") @db.VarChar(3)
  exchangeRate    Decimal?  @map("exchange_rate") @db.Decimal(16, 8)
  category    String
  paidBy      PaidBy        @default(PERSONAL) @map("paid_by")
  description String?
  expenseDate DateTime      @map("expense_date") @db.Date
  receiptPath String?       @map("receipt_path")
  status      ExpenseStatus @default(DRAFT)
  currentStep Int           @default(0) @map("current_step")
  workflowId  String?       @map("workflow_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflow    ApprovalWorkflow? @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  approvals   ExpenseApproval[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([workflowId])
  @@map("expenses")
}

model ExpenseApproval {
  id         String         @id @default(uuid())
  expenseId  String         @map("expense_id")
  approverId String         @map("approver_id")
  stepNumber Int            @map("step_number")
  action     ApprovalAction @default(PENDING)
  comment    String?
  decidedAt  DateTime?      @map("decided_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  expense    Expense        @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approver   User           @relation("Approver", fields: [approverId], references: [id], onDelete: Cascade)

  @@unique([expenseId, approverId, stepNumber])
  @@index([expenseId])
  @@index([approverId])
  @@map("expense_approvals")
}

model ApprovalWorkflow {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String
  description String?
  minAmount   Decimal? @map("min_amount") @db.Decimal(12, 2)
  maxAmount   Decimal? @map("max_amount") @db.Decimal(12, 2)
  category    String?
  isDefault          Boolean  @default(false) @map("is_default")
  isActive           Boolean  @default(true) @map("is_active")
  isManagerApprover  Boolean  @default(true) @map("is_manager_approver")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps       ApprovalStep[]
  expenses    Expense[]

  @@index([companyId])
  @@index([isActive])
  @@map("approval_workflows")
}

model ApprovalStep {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  stepNumber  Int      @map("step_number")
  approverId  String?  @map("approver_id")
  approverRole Role?   @map("approver_role")
  isRequired  Boolean  @default(true) @map("is_required")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  workflow    ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approver   User?            @relation(fields: [approverId], references: [id], onDelete: SetNull)

  rules       StepRule[]

  @@unique([workflowId, stepNumber])
  @@index([workflowId])
  @@map("approval_steps")
}

model ApprovalRule {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  name            String
  ruleType        RuleType @map("rule_type")
  // For PERCENTAGE: threshold percentage (e.g., 60 means 60% approval needed)
  percentageThreshold Int? @map("percentage_threshold")
  // For SPECIFIC_APPROVER: the user who can auto-approve
  specificApproverId  String? @map("specific_approver_id")
  // For amount-based rules
  minAmount       Decimal? @map("min_amount") @db.Decimal(12, 2)
  maxAmount       Decimal? @map("max_amount") @db.Decimal(12, 2)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stepRules       StepRule[]

  @@index([companyId])
  @@map("approval_rules")
}

model StepRule {
  id       String       @id @default(uuid())
  stepId   String       @map("step_id")
  ruleId   String       @map("rule_id")

  step     ApprovalStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  rule     ApprovalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([stepId, ruleId])
  @@map("step_rules")
}
